#!/usr/bin/env node

/**
 * collab — CLI for agentic-collab orchestrator.
 *
 * Auto-discovers orchestrator URL and shared secret.
 * Designed to be used by agents inside tmux sessions or by humans on the host.
 *
 * Environment variables (all optional — auto-discovery handles the common case):
 *   ORCHESTRATOR_URL        — Override orchestrator URL
 *   ORCHESTRATOR_SECRET     — Override secret
 *   ORCHESTRATOR_SECRET_FILE — Override secret file path
 *   COLLAB_AGENT            — Default agent name for send/reply (set by orchestrator)
 */

import { readFileSync, existsSync } from 'node:fs';
import { basename, join, resolve } from 'node:path';
import { homedir } from 'node:os';
import { execSync } from 'node:child_process';

// ── Config Resolution ──

const CONFIG_DIR = process.env['AGENTIC_COLLAB_CONFIG_DIR']
  ?? join(homedir(), '.config', 'agentic-collab');

function resolveSecret() {
  const env = process.env['ORCHESTRATOR_SECRET'];
  if (env !== undefined) return env || null;

  const file = process.env['ORCHESTRATOR_SECRET_FILE'];
  if (file) {
    try { return readFileSync(file, 'utf-8').trim() || null; } catch { return null; }
  }

  try {
    return readFileSync(join(CONFIG_DIR, 'secret'), 'utf-8').trim() || null;
  } catch { return null; }
}

function discoverViaDocker() {
  try {
    const raw = execSync(
      'docker ps --filter "label=io.agentic-collab.role=orchestrator" --format "{{.Ports}}"',
      { timeout: 5000, stdio: ['pipe', 'pipe', 'pipe'] },
    ).toString().trim();
    if (!raw) return null;
    const match = raw.match(/(?:\d+\.\d+\.\d+\.\d+|::):(\d+)->/);
    if (match) return `http://localhost:${match[1]}`;
  } catch {}
  return null;
}

async function discoverOrchestrator() {
  const env = process.env['ORCHESTRATOR_URL'];
  if (env) return env;

  const docker = discoverViaDocker();
  if (docker) {
    try {
      const r = await fetch(`${docker}/api/orchestrator/status`, { signal: AbortSignal.timeout(3000) });
      if (r.ok) return docker;
    } catch {}
  }

  for (const port of [3000, 3001]) {
    const url = `http://localhost:${port}`;
    try {
      const r = await fetch(`${url}/api/orchestrator/status`, { signal: AbortSignal.timeout(3000) });
      if (r.ok) return url;
    } catch {}
  }

  return null;
}

// ── HTTP Helpers ──

let _host = null;
let _secret = null;

async function init() {
  _secret = resolveSecret();
  _host = await discoverOrchestrator();
  if (!_host) {
    console.error('error: could not find orchestrator (tried Docker discovery + localhost:3000/3001)');
    console.error('  set ORCHESTRATOR_URL or start the orchestrator first');
    process.exit(1);
  }
}

function headers() {
  const h = { 'content-type': 'application/json' };
  if (_secret) h['authorization'] = `Bearer ${_secret}`;
  return h;
}

async function api(method, path, body) {
  const opts = { method, headers: headers() };
  if (body !== undefined) opts.body = JSON.stringify(body);
  const resp = await fetch(`${_host}${path}`, opts);
  const text = await resp.text();
  let data;
  try { data = JSON.parse(text); } catch { data = text; }
  if (!resp.ok) {
    const msg = typeof data === 'object' ? data.error || JSON.stringify(data) : data;
    console.error(`error: ${resp.status} ${msg}`);
    process.exit(1);
  }
  return data;
}

function agentName() {
  return process.env['COLLAB_AGENT'] || null;
}

function requireAgentName(explicit) {
  const name = explicit || agentName();
  if (!name) {
    console.error('error: agent name required (pass as argument or set COLLAB_AGENT)');
    process.exit(1);
  }
  return name;
}

// ── Commands ──

const COMMANDS = {};

function cmd(name, usage, desc, fn) {
  COMMANDS[name] = { usage, desc, fn };
}

function formatReplyContext(message, inReplyTo) {
  return inReplyTo ? `In reply to: ${inReplyTo}\n\n${message}` : message;
}

function parseSendArgs(args, implicitTarget = null) {
  let topic = null;
  let replyReminder = null;
  let inReplyTo = null;
  const target = implicitTarget ?? args[0];
  const positional = [];
  const startIdx = implicitTarget ? 0 : 1;

  for (let i = startIdx; i < args.length; i++) {
    if (args[i] === '--topic' && args[i + 1]) { topic = args[++i]; }
    else if (args[i] === '--in-reply-to' && args[i + 1]) { inReplyTo = args[++i]; }
    else if (args[i] === '--reply-reminder') {
      const next = args[i + 1];
      if (next && !next.startsWith('-')) { replyReminder = parseInt(args[++i], 10); }
      else { replyReminder = 30; }
    }
    else { positional.push(args[i]); }
  }

  return {
    target,
    topic,
    replyReminder,
    inReplyTo,
    message: positional.join(' '),
  };
}

async function dispatchSend({ target, topic, message, replyReminder, inReplyTo }) {
  if (!target || !topic || !message) {
    console.error('usage: collab send <target> --topic <topic> [--in-reply-to <text>] <message>');
    process.exit(1);
  }

  const formattedMessage = formatReplyContext(message, inReplyTo);
  if (target === 'operator' || target === 'dashboard') {
    if (replyReminder) {
      console.error('error: --reply-reminder is only supported when messaging another agent');
      process.exit(1);
    }
    const agent = requireAgentName();
    await api('POST', '/api/dashboard/reply', { agent, message: formattedMessage, topic });
    console.log('sent');
    return;
  }

  const from = requireAgentName();
  const body = { from, to: target, message: formattedMessage, topic };
  if (replyReminder) body.replyReminder = replyReminder;
  const data = await api('POST', '/api/agents/send', body);
  console.log(`queued (id:${data.queueId})`);
}

cmd('agents', 'agents', 'List all agents', async () => {
  const agents = await api('GET', '/api/agents');
  if (agents.length === 0) { console.log('No agents'); return; }
  const maxName = Math.max(...agents.map(a => a.name.length), 4);
  for (const a of agents) {
    const ctx = a.lastContextPct != null ? `${a.lastContextPct}%` : '--';
    console.log(
      `${a.name.padEnd(maxName)}  ${a.state.padEnd(10)}  ${a.engine.padEnd(8)}  ctx:${ctx}`
    );
  }
});

COMMANDS['list-agents'] = {
  ...COMMANDS['agents'],
  usage: 'list-agents',
  desc: 'List all agents',
};

cmd('status', 'status', 'Orchestrator status', async () => {
  const s = await api('GET', '/api/orchestrator/status');
  console.log(`agents: ${s.totalAgents}  proxies: ${s.totalProxies}`);
  if (s.byState && Object.keys(s.byState).length > 0) {
    console.log(`  ${Object.entries(s.byState).map(([k, v]) => `${k}:${v}`).join('  ')}`);
  }
});

cmd('send', 'send <target> --topic <topic> [--in-reply-to <text>] <message>', 'Send a message to operator or another agent', async (args) => {
  await dispatchSend(parseSendArgs(args));
});

cmd('reply', 'reply --topic <topic> [--in-reply-to <text>] <message>', 'Compatibility alias for send operator', async (args) => {
  await dispatchSend(parseSendArgs(args, 'operator'));
});

cmd('spawn', 'spawn <name> [task...]', 'Spawn an agent', async (args) => {
  const name = args[0];
  if (!name) { console.error('usage: collab spawn <name> [task...]'); process.exit(1); }
  const task = args.slice(1).join(' ') || undefined;
  const data = await api('POST', `/api/agents/${encodeURIComponent(name)}/spawn`, { task });
  console.log(`${data.name} → ${data.state}`);
});

cmd('create', 'create <name> <engine> <cwd>', 'Create a new agent', async (args) => {
  const [name, engine, cwd] = args;
  if (!name || !engine || !cwd) { console.error('usage: collab create <name> <engine> <cwd>'); process.exit(1); }
  const data = await api('POST', '/api/agents', { name, engine, cwd });
  console.log(`created ${data.name} (${data.engine})`);
});

cmd('create-agent', 'create-agent <persona-file>', 'Create or update an agent from a persona file', async (args) => {
  const personaFile = args[0];
  if (!personaFile) {
    console.error('usage: collab create-agent <persona-file>');
    process.exit(1);
  }
  const filePath = resolve(personaFile);
  if (!existsSync(filePath)) {
    console.error(`error: persona file not found: ${filePath}`);
    process.exit(1);
  }
  const content = readFileSync(filePath, 'utf-8');
  if (!content.trim()) {
    console.error(`error: persona file is empty: ${filePath}`);
    process.exit(1);
  }
  const name = basename(filePath).replace(/\.md$/i, '');
  const data = await api('POST', '/api/personas', { name, content });
  console.log(`materialized ${data.agent.name} from ${basename(filePath)}`);
});

cmd('exit', 'exit <name>', 'Exit an agent (suspend)', async (args) => {
  const name = args[0];
  if (!name) { console.error('usage: collab exit <name>'); process.exit(1); }
  await api('POST', `/api/agents/${encodeURIComponent(name)}/exit`);
  console.log(`${name} exited`);
});
// Hidden backward-compat alias
COMMANDS['suspend'] = { ...COMMANDS['exit'], hidden: true };

cmd('resume', 'resume <name> [task...]', 'Resume a suspended agent', async (args) => {
  const name = args[0];
  if (!name) { console.error('usage: collab resume <name> [task...]'); process.exit(1); }
  const task = args.slice(1).join(' ') || undefined;
  const data = await api('POST', `/api/agents/${encodeURIComponent(name)}/resume`, { task });
  console.log(`${data.name} → ${data.state}`);
});

cmd('interrupt', 'interrupt <name>', 'Interrupt an agent', async (args) => {
  const name = args[0];
  if (!name) { console.error('usage: collab interrupt <name>'); process.exit(1); }
  await api('POST', `/api/agents/${encodeURIComponent(name)}/interrupt`);
  console.log(`${name} interrupted`);
});

cmd('compact', 'compact <name>', 'Compact agent context', async (args) => {
  const name = args[0];
  if (!name) { console.error('usage: collab compact <name>'); process.exit(1); }
  await api('POST', `/api/agents/${encodeURIComponent(name)}/compact`);
  console.log(`${name} compacting`);
});

cmd('kill', 'kill <name>', 'Kill an agent session', async (args) => {
  const name = args[0];
  if (!name) { console.error('usage: collab kill <name>'); process.exit(1); }
  await api('POST', `/api/agents/${encodeURIComponent(name)}/kill`);
  console.log(`${name} killed`);
});

cmd('destroy', 'destroy <name>', 'Permanently destroy an agent', async (args) => {
  const name = args[0];
  if (!name) { console.error('usage: collab destroy <name>'); process.exit(1); }
  await api('DELETE', `/api/agents/${encodeURIComponent(name)}`);
  console.log(`${name} destroyed`);
});

cmd('queue', 'queue [--agent <name>]', 'List pending messages', async (args) => {
  let agent = '';
  for (let i = 0; i < args.length; i++) {
    if (args[i] === '--agent' && args[i + 1]) agent = args[++i];
  }
  const params = agent ? `?agent=${encodeURIComponent(agent)}` : '';
  const messages = await api('GET', `/api/queue${params}`);
  if (messages.length === 0) { console.log('No pending messages'); return; }
  for (const m of messages) {
    console.log(`[${m.id}] ${m.sourceAgent || 'dashboard'} → ${m.targetAgent}  ${m.status}  ${m.envelope.slice(0, 80)}`);
  }
});

cmd('events', 'events <name> [--limit N]', 'View agent event log', async (args) => {
  const name = args[0];
  if (!name) { console.error('usage: collab events <name>'); process.exit(1); }
  let limit = 20;
  for (let i = 1; i < args.length; i++) {
    if (args[i] === '--limit' && args[i + 1]) limit = parseInt(args[++i], 10);
  }
  const events = await api('GET', `/api/events/${encodeURIComponent(name)}?limit=${limit}`);
  if (events.length === 0) { console.log('No events'); return; }
  for (const e of events) {
    console.log(`${e.createdAt}  ${e.event}${e.meta ? '  ' + e.meta : ''}`);
  }
});

cmd('peek', 'peek <name>', 'Peek at agent tmux pane output', async (args) => {
  const name = args[0];
  if (!name) { console.error('usage: collab peek <name>'); process.exit(1); }
  const data = await api('GET', `/api/agents/${encodeURIComponent(name)}/peek`);
  console.log(data.output);
});

cmd('keys', 'keys <name> <keys>', 'Send tmux keys to an agent', async (args) => {
  const name = args[0];
  const keys = args.slice(1).join(' ');
  if (!name || !keys) { console.error('usage: collab keys <name> <keys>'); process.exit(1); }
  await api('POST', `/api/agents/${encodeURIComponent(name)}/keys`, { keys });
  console.log(`sent keys to ${name}`);
});

cmd('reload', 'reload <name> [task...]', 'Reload an agent (kill + respawn)', async (args) => {
  const name = args[0];
  if (!name) { console.error('usage: collab reload <name> [task...]'); process.exit(1); }
  const task = args.slice(1).join(' ') || undefined;
  await api('POST', `/api/agents/${encodeURIComponent(name)}/reload`, { immediate: true, task });
  console.log(`${name} reloading`);
});

cmd('tmux', 'tmux <agent> -- <tmux args...>', 'Run a constrained tmux command against an agent session', async (args) => {
  const name = args[0];
  const dashIdx = args.indexOf('--');
  const tmuxArgs = dashIdx === -1 ? args.slice(1) : args.slice(dashIdx + 1);
  if (!name || tmuxArgs.length === 0) {
    console.error('usage: collab tmux <agent> -- <tmux args...>');
    process.exit(1);
  }
  const data = await api('POST', `/api/agents/${encodeURIComponent(name)}/tmux`, { args: tmuxArgs });
  if (data.data == null) {
    console.log('ok');
  } else if (typeof data.data === 'string') {
    console.log(data.data);
  } else if (typeof data.data === 'number' || typeof data.data === 'boolean') {
    console.log(String(data.data));
  } else {
    console.log(JSON.stringify(data.data, null, 2));
  }
});

// ── Reminders ──

cmd('reminder', 'reminder <sub> [args...]', 'Manage reminders (add|list|done|cancel|swap)', async (args) => {
  const sub = args[0];
  const sargs = args.slice(1);

  if (sub === 'add') {
    // collab reminder add <agent> "<prompt>" --cadence 10m [--at HH:MM] [--from <name>]
    let cadence = null, from = null, at = null;
    const positional = [];
    for (let i = 0; i < sargs.length; i++) {
      if (sargs[i] === '--cadence' && sargs[i + 1]) { cadence = sargs[++i]; }
      else if (sargs[i] === '--at' && sargs[i + 1]) { at = sargs[++i]; }
      else if (sargs[i] === '--from' && sargs[i + 1]) { from = sargs[++i]; }
      else { positional.push(sargs[i]); }
    }
    const targetAgent = positional[0];
    const prompt = positional.slice(1).join(' ');
    if (!targetAgent || !prompt) {
      console.error('usage: collab reminder add <agent> "<prompt>" --cadence 10m [--at HH:MM] [--from <name>]');
      process.exit(1);
    }
    // --at HH:MM enables clock-time delivery (daily at that local time)
    if (at) {
      if (!/^\d{2}:\d{2}$/.test(at)) { console.error('error: --at must be HH:MM (e.g. 06:00)'); process.exit(1); }
      const createdBy = from || agentName() || undefined;
      const body = { agentName: targetAgent, prompt, cadenceMinutes: 1440, deliverAt: at, createdBy };
      const reminder = await api('POST', '/api/reminders', body);
      console.log(`created reminder #${reminder.id} for ${targetAgent} (daily at ${at})`);
    } else {
      // parse cadence: "10m" → 10, "30m" → 30, bare number → minutes
      let cadenceMinutes = 30;
      if (cadence) {
        const m = cadence.match(/^(\d+)m?$/);
        if (!m) { console.error('error: --cadence must be like 10m or 30'); process.exit(1); }
        cadenceMinutes = parseInt(m[1], 10);
      }
      if (cadenceMinutes < 5) { console.error('error: cadence must be >= 5 minutes'); process.exit(1); }
      const createdBy = from || agentName() || undefined;
      const reminder = await api('POST', '/api/reminders', { agentName: targetAgent, prompt, cadenceMinutes, createdBy });
      console.log(`created reminder #${reminder.id} for ${targetAgent} (every ${cadenceMinutes}m)`);
    }
  }

  else if (sub === 'list') {
    // collab reminder list [--agent <name>]
    let agent = null;
    for (let i = 0; i < sargs.length; i++) {
      if (sargs[i] === '--agent' && sargs[i + 1]) { agent = sargs[++i]; }
    }
    const query = agent ? `?agent=${encodeURIComponent(agent)}` : '';
    const reminders = await api('GET', `/api/reminders${query}`);
    if (reminders.length === 0) { console.log('No reminders'); return; }
    const pending = reminders.filter(r => r.status === 'pending');
    const completed = reminders.filter(r => r.status === 'completed');
    const maxId = Math.max(...reminders.map(r => r.id.toString().length), 2);
    const maxAgent = Math.max(...reminders.map(r => r.agentName.length), 5);
    const maxPrompt = Math.min(Math.max(...reminders.map(r => r.prompt.length), 6), 50);

    const printRows = (title, rows) => {
      if (rows.length === 0) return;
      if (title) console.log(title);
      console.log(`${'ID'.padEnd(maxId)}  ${'Agent'.padEnd(maxAgent)}  ${'Prompt'.padEnd(maxPrompt)}  Cadence   Status`);
      for (const r of rows) {
        const prompt = r.prompt.length > 50 ? r.prompt.slice(0, 47) + '...' : r.prompt;
        const schedule = r.deliverAt ? `at ${r.deliverAt}` : `${r.cadenceMinutes}m`;
        const cadence = schedule.padEnd(9);
        const status = r.status === 'completed' ? 'done' : 'pending';
        console.log(`${r.id.toString().padEnd(maxId)}  ${r.agentName.padEnd(maxAgent)}  ${prompt.padEnd(maxPrompt)}  ${cadence} ${status}`);
      }
    };

    printRows('', pending);
    if (completed.length > 0) {
      if (pending.length > 0) console.log('');
      printRows('Recently completed', completed);
    }
  }

  else if (sub === 'done') {
    // collab reminder done <id>
    const id = parseInt(sargs[0], 10);
    if (isNaN(id)) { console.error('usage: collab reminder done <id>'); process.exit(1); }
    await api('POST', `/api/reminders/${id}/complete`);
    console.log(`reminder #${id} completed`);
  }

  else if (sub === 'cancel') {
    // collab reminder cancel <id>
    const id = parseInt(sargs[0], 10);
    if (isNaN(id)) { console.error('usage: collab reminder cancel <id>'); process.exit(1); }
    await api('DELETE', `/api/reminders/${id}`);
    console.log(`reminder #${id} cancelled`);
  }

  else if (sub === 'swap') {
    // collab reminder swap <id1> <id2>
    const id1 = parseInt(sargs[0], 10);
    const id2 = parseInt(sargs[1], 10);
    if (isNaN(id1) || isNaN(id2)) { console.error('usage: collab reminder swap <id1> <id2>'); process.exit(1); }
    await api('POST', '/api/reminders/swap', { id1, id2 });
    console.log(`swapped reminder #${id1} ↔ #${id2}`);
  }

  else {
    console.error(`unknown subcommand: ${sub}`);
    console.error('usage: collab reminder {add|list|done|cancel|swap}');
    process.exit(1);
  }
});

// ── Main ──

function showHelp() {
  console.log('collab — CLI for agentic-collab orchestrator\n');
  console.log('Usage: collab <command> [args...]\n');
  console.log('Commands:');
  const visible = Object.values(COMMANDS).filter(c => !c.hidden);
  const maxUsage = Math.max(...visible.map(c => c.usage.length));
  for (const c of visible) {
    console.log(`  ${c.usage.padEnd(maxUsage + 2)}  ${c.desc}`);
  }
  console.log('\nNotes:');
  console.log('  operator                The human operator in the dashboard');
  console.log('\nEnvironment:');
  console.log('  COLLAB_AGENT            Your agent name (auto-set by orchestrator)');
  console.log('  ORCHESTRATOR_URL        Override orchestrator URL');
  console.log('  ORCHESTRATOR_SECRET     Override secret');
}

[
  'agents',
  'status',
  'reply',
  'spawn',
  'create',
  'exit',
  'suspend',
  'resume',
  'interrupt',
  'compact',
  'kill',
  'destroy',
  'queue',
  'events',
  'peek',
  'keys',
  'reload',
  'reminder',
].forEach((name) => {
  if (COMMANDS[name]) COMMANDS[name].hidden = true;
});

async function main() {
  const args = process.argv.slice(2);
  const command = args[0];

  if (!command || command === '--help' || command === '-h' || command === 'help') {
    showHelp();
    process.exit(0);
  }

  const handler = COMMANDS[command];
  if (!handler) {
    console.error(`unknown command: ${command}`);
    console.error(`run 'collab help' for usage`);
    process.exit(1);
  }

  await init();
  await handler.fn(args.slice(1));
}

main().catch((err) => {
  console.error(`error: ${err.message}`);
  process.exit(1);
});
